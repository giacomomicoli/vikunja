# Example values for a fresh setup. Replace them for your environment before production use.

# === Vikunja ===
VIKUNJA_PUBLIC_URL=http://localhost:3456/
VIKUNJA_DOMAIN=vikunja.example.com
VIKUNJA_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
VIKUNJA_DB_PASSWORD=CHANGE_ME
VIKUNJA_VERSION=2.2.2
POSTGRES_VERSION=16

# === Defaults shown to new users ===
VIKUNJA_SERVICE_TIMEZONE=UTC
VIKUNJA_DEFAULTSETTINGS_LANGUAGE=en-US
VIKUNJA_DEFAULTSETTINGS_WEEK_START=1
VIKUNJA_DEFAULTSETTINGS_TIMEZONE=UTC

# === Deployment paths ===
VIKUNJA_SERVER_PATH=/srv/vikunja
VIKUNJA_FILES_PATH=/srv/vikunja/files
VIKUNJA_BACKUPS_PATH=/srv/vikunja/backups

# === Networking ===
TRAEFIK_PUBLIC_NETWORK=traefik-public
TRAEFIK_PROXY_CIDR=192.0.2.0/24

# === Registration ===
VIKUNJA_ENABLE_REGISTRATION=true

# === Mailer ===
VIKUNJA_MAILER_ENABLED=false
VIKUNJA_MAILER_HOST=
VIKUNJA_MAILER_PORT=587
VIKUNJA_MAILER_AUTHTYPE=plain
VIKUNJA_MAILER_USERNAME=
VIKUNJA_MAILER_PASSWORD=
VIKUNJA_MAILER_FROMEMAIL=vikunja@example.com

# Optional: override the image reference for manual deploys.
# The GitHub Actions deploy workflow exports this automatically.
# VIKUNJA_IMAGE=ghcr.io/<owner>/vikunja:latest
